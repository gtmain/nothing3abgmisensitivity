/* ──────────────────────────────────────
   SCROLL REVEAL
────────────────────────────────────── */
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), i * 80);
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
revealEls.forEach(el => observer.observe(el));

/* ──────────────────────────────────────
   ANIMATED BARS (trigger on scroll)
────────────────────────────────────── */
function animateBars(container) {
  const fills = container.querySelectorAll('.vis-bar-fill');
  fills.forEach(fill => {
    const target = parseFloat(fill.dataset.val);
    fill.style.width = target + '%';
  });
}
const barObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      setTimeout(() => animateBars(e.target), 300);
      barObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
document.querySelectorAll('.vis-wrap').forEach(el => barObserver.observe(el));

